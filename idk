local function runScan()
    scanning = true; stopScan = false; scannedServers = 0; totalServers = 0
    foundJobId = nil; targetAvatarUrl = nil; totalErrors = 0; rateLimitHits = 0
    for i = 1,CONCURRENCY do setWorker(i,"idle") end

    for _,p in ipairs(Players:GetPlayers()) do
        if p.Name:lower()==targetUsername:lower() then
            StatusLabel.Text = "In YOUR server!"; StatusLabel.TextColor3 = Color3.fromRGB(50,210,95)
            ProgFill.Size = UDim2.new(1,0,1,0); ProgFill.BackgroundColor3 = Color3.fromRGB(50,210,95)
            addLog(targetUsername.." already here!",Color3.fromRGB(70,255,120))
            reportFound(game.JobId,"Local Server"); scanning = false; StopBtn.Visible = false; return
        end
    end

    addLog("Presence API...",Color3.fromRGB(110,165,255))
    local presJob = m_presence()
    if presJob then onFound(presJob,"Presence API"); scanning = false; StopBtn.Visible = false; return end
    addLog("Presence blocked — full scan",Color3.fromRGB(170,140,90))

    fetchAvatar()
    if targetAvatarUrl then addLog("Avatar cached",Color3.fromRGB(130,190,130)) end

    local allServers = {}; local cursor = ""
    StatusLabel.Text = "Fetching servers..."; addLog("Fetching servers...",Color3.fromRGB(190,190,120))
    repeat
        if stopScan then break end
        local page,err = getServersPage(cursor)
        if not page then
            if err=="ratelimit" then addLog("RL — wait 3s",Color3.fromRGB(255,140,50)); task.wait(3)
            else addLog("Fetch failed",Color3.fromRGB(255,140,50)); break end
        else
            for _,s in ipairs(page.data or {}) do table.insert(allServers,s) end
            cursor = page.nextPageCursor or ""; task.wait(0.05)
        end
    until cursor=="" or stopScan

    totalServers = #allServers; updateStats()
    addLog(string.format("%d servers — %d workers",totalServers,CONCURRENCY),Color3.fromRGB(190,190,120))
    StatusLabel.Text = string.format("Scanning %d servers...",totalServers)
    StatusLabel.TextColor3 = Color3.fromRGB(160,165,230)

    local startTime = tick(); local serverIndex = 0; local globalRL = false

    while serverIndex<#allServers and not stopScan and not foundJobId do
        local batch = {}
        for w = 1,CONCURRENCY do
            serverIndex += 1
            if serverIndex>#allServers then break end
            table.insert(batch,{w=w,server=allServers[serverIndex]})
        end

        local results = {}; local done = 0; local batchSize = #batch
        for _,job in ipairs(batch) do
            task.spawn(function()
                if foundJobId or stopScan then done += 1; return end
                setWorker(job.w,"scanning")
                local r = checkServer(job.server)
                results[job.w] = {r=r,server=job.server}
                if r=="ratelimit" then setWorker(job.w,"ratelimit"); globalRL = true
                elseif r=="found" then setWorker(job.w,"found")
                elseif r=="error" then setWorker(job.w,"error")
                else setWorker(job.w,"idle") end
                done += 1
            end)
        end

        local t = 0
        while done<batchSize do task.wait(0.01); t += 0.01; if t>10 then break end end

        for _,r in pairs(results) do
            if r.r=="found" and not foundJobId then onFound(r.server.id,"Parallel Scan"); break
            elseif r.r=="ratelimit" then rateLimitHits += 1; totalErrors += 1
            elseif r.r=="error" then totalErrors += 1 end
        end

        scannedServers = math.min(serverIndex,totalServers); updateStats()
        local elapsed = tick()-startTime
        if elapsed>0 and scannedServers>0 then
            local sps = scannedServers/elapsed
            SpeedReadout.Text = string.format("%.1f sv/s  ETA ~%.0fs",sps,(totalServers-scannedServers)/math.max(sps,0.1))
            SpeedReadout.TextColor3 = sps>=5 and Color3.fromRGB(60,210,100) or Color3.fromRGB(200,175,70)
        end
        StatusLabel.Text = string.format("%d/%d [%.0f%%]",scannedServers,totalServers,(scannedServers/totalServers)*100)

        if globalRL and not foundJobId then
            globalRL = false
            addLog(string.format("Rate limited — cooling 4s (%d hits)",rateLimitHits),Color3.fromRGB(255,75,75))
            stroke.Color = Color3.fromRGB(255,75,75); task.wait(4); stroke.Color = Color3.fromRGB(70,110,240)
        else
            task.wait(POLL_DELAY)
        end
    end

    if not foundJobId and not stopScan then
        StatusLabel.Text = "Not found"; StatusLabel.TextColor3 = Color3.fromRGB(255,90,90)
        addLog(string.format("%d servers scanned — not found",totalServers),Color3.fromRGB(255,90,90))
        addLog("Add target as Roblox friend for instant find",Color3.fromRGB(190,110,70))
        for i = 1,CONCURRENCY do setWorker(i,"idle") end
    end
    scanning = false; StopBtn.Visible = false
end

