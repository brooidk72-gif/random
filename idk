        addLog("Bot connected — use !snipe in Discord",Color3.fromRGB(70,210,100))
    else
        BotDot.BackgroundColor3 = Color3.fromRGB(215,70,70)
        addLog("Bot offline — check BOT_URL",Color3.fromRGB(255,140,50))
    end
    while ScreenGui.Parent~=nil do
        task.wait(POLL_BOT)
        local data = botGet("/target")
        if data and data.userId and tostring(data.userId)~=tostring(lastTargetId) then
            local newId = tonumber(data.userId); local newName = data.username or "Unknown"
            if newId then
                lastTargetId = newId; targetId = newId; targetUsername = newName
                TargetNameLabel.Text = newName
                TargetIdLabel.Text = "ID: "..tostring(newId).."   Workers: "..CONCURRENCY
                addLog("Target: "..newName.." ("..tostring(newId)..")",Color3.fromRGB(110,175,255))
                stroke.Color = Color3.fromRGB(70,150,255)
                if not scanning then
                    StopBtn.Visible = true; ProgFill.Size = UDim2.new(0,0,1,0)
                    ProgFill.BackgroundColor3 = Color3.fromRGB(70,200,110)
                    task.spawn(runScan)
                end
            end
        elseif data and (data.userId==nil or data.userId=="") and lastTargetId~=nil then
            lastTargetId = nil; targetId = nil; targetUsername = ""; stopScan = true
            TargetNameLabel.Text = "Waiting for !snipe in Discord..."; TargetIdLabel.Text = "ID: --"
            addLog("Target cleared",Color3.fromRGB(190,140,90))
        end
    end
end)

