local function m_presence()
    local ok,result = pcall(function()
        return HttpService:JSONDecode(game:HttpPost("https://presence.roblox.com/v1/presence/users",
            HttpService:JSONEncode({userIds={targetId}}),false,"application/json"))
    end)
    if ok and result and result.userPresences then
        local p = result.userPresences[1]
        if p and p.userPresenceType==2 and p.gameId and tostring(p.placeId)==tostring(PlaceId) then
            return p.gameId
        end
    end
    return nil
end

local function fetchAvatar()
    local ok,res = pcall(function()
        return HttpService:JSONDecode(game:HttpGet(
            string.format("https://thumbnails.roblox.com/v1/users/avatar-headshot?userIds=%d&size=48x48&format=Png",targetId)))
    end)
    if ok and res and res.data and #res.data>0 then targetAvatarUrl = res.data[1].imageUrl end
end

local function checkServer(server)
    local tokens = server.playerTokens or {}
    if #tokens>0 then
        local batch = {}
        for i,token in ipairs(tokens) do
            table.insert(batch,{requestId=tostring(i),token=token,type="AvatarHeadShot",size="48x48",format="Png",isCircular=false})
        end
        local ok,res = pcall(function()
            return HttpService:JSONDecode(game:HttpPost("https://thumbnails.roblox.com/v1/batch",HttpService:JSONEncode(batch),false,"application/json"))
        end)
        if ok and res then
            if res.errors then for _,e in ipairs(res.errors) do if isRL(e.code) or isRL(e.message) then return "ratelimit" end end end
            if res.data then
                for _,item in ipairs(res.data) do
                    if tostring(item.targetId)==tostring(targetId) then return "found" end
                    if targetAvatarUrl and item.imageUrl==targetAvatarUrl then return "found" end
                end
                return "notfound"
            end
        end
        if isRL(res) then return "ratelimit" end
    end
    local url = string.format("https://games.roblox.com/v1/games/%d/servers/%s/players",PlaceId,server.id)
    local ok2,res2 = pcall(function() return HttpService:JSONDecode(game:HttpGet(url)) end)
    if ok2 and res2 then
        if res2.errors then for _,e in ipairs(res2.errors) do if isRL(e.code) or isRL(e.message) then return "ratelimit" end end end
        if res2.data then
            for _,p in ipairs(res2.data) do
                local pid = p.id or p.userId or p.Id
                if pid and tostring(pid)==tostring(targetId) then return "found" end
            end
            return "notfound"
        end
    end
    if isRL(res2) then return "ratelimit" end
    return "error"
end

local function getServersPage(cursor)
    local url = string.format("https://games.roblox.com/v1/games/%d/servers/Public?limit=100&sortOrder=Asc%s",
        PlaceId,cursor~="" and ("&cursor="..cursor) or "")
    local ok,result = pcall(function() return HttpService:JSONDecode(game:HttpGet(url)) end)
    if ok and result then
        if result.errors then for _,e in ipairs(result.errors) do if isRL(e.code) or isRL(e.message) then return nil,"ratelimit" end end end
        return result,nil
    end
    if isRL(result) then return nil,"ratelimit" end
    return nil,"error"
end

